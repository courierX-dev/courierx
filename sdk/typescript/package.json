{
  "name": "@courierx/node",
  "version": "0.1.0",
  "description": "Official Node.js SDK for CourierX — multi-provider email delivery platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "courierx",
    "email",
    "sendgrid",
    "mailgun",
    "ses",
    "postmark",
    "resend",
    "smtp",
    "email-api",
    "transactional-email"
  ],
  "author": "CourierX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/courierx-dev/courierx.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://courierx.dev",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
