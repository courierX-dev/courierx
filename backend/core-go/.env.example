# CourierX Core — environment template
# Copy to .env for local development, or manage with Phase for staging/production.
# Phase docs: https://docs.phase.dev
#
# Usage:
#   phase run -- go run .           # inject env from Phase vault
#   phase run -- ./courierx-core    # inject env for compiled binary

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
GO_ENV=development                  # development | production

# ── Database (shared with Rails Control Plane) ────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/courierx_development"
# Set to "skip" or leave empty to run without a DB (benchmark mode)

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret between the Rails Control Plane and this service.
# The control plane sets X-Internal-Secret on every request.
# Required in production; leave empty to bypass auth in development.
INTERNAL_SECRET=""

# ── Provider credentials ──────────────────────────────────────────────────────
# Configure at least one provider. Multiple providers = automatic failover.
# Priority order: SendGrid → Mailgun → SES → Postmark → Resend → SMTP

# SendGrid
SENDGRID_API_KEY=""

# Mailgun
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_REGION="us"                 # "us" or "eu"

# AWS SES (Signature V4 — no SDK required)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# Postmark (Server API Token)
POSTMARK_API_KEY=""

# Resend
RESEND_API_KEY=""

# Generic SMTP
SMTP_HOST=""
SMTP_PORT=587                       # 587 = STARTTLS, 465 = implicit TLS
SMTP_USER=""
SMTP_PASS=""
SMTP_USE_TLS=false                  # true for implicit TLS (port 465)

# ── Redis (future: distributed idempotency + job queue) ───────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# DSN from https://sentry.io — separate project from Rails/Next.js.
# Leave empty to disable.
SENTRY_GO_DSN=""

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"                    # debug | info | warn | error
LOG_FORMAT="json"                   # json | text

# ── Performance ───────────────────────────────────────────────────────────────
MAX_WORKERS=100                     # goroutines for parallel batch sends
QUEUE_BUFFER_SIZE=1000
RATE_LIMIT_PER_PROVIDER=1000        # max sends/sec per provider (token bucket)

# ── Idempotency ───────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL=86400               # seconds (default 24 h)

# ── Control Plane ─────────────────────────────────────────────────────────────
CONTROL_PLANE_URL="http://localhost:4000"

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_METRICS=true                 # exposes GET /metrics (JSON counters)
ENABLE_TRACING=false                # OpenTelemetry (future)
ENABLE_IP_WARMING=false             # IP warming schedule (future)
