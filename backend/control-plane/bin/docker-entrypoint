#!/bin/bash -e

# Note: this entrypoint is only used by backend/control-plane/Dockerfile (local
# dev / kamal). Production on Railway uses infra/docker/Dockerfile.rails which
# has no entrypoint; migrations there run via the Railway Pre-deploy Command
# (`bundle exec rails db:migrate:with_data`).
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
