source "https://rubygems.org"

# Pin connection_pool to 2.x for Ruby 3.3 compatibility
# (3.x uses Ruby 3.4+ syntax)
gem "connection_pool", "~> 2.4"

gem "rails", "~> 8.1.1"
gem "pg", "~> 1.1"
gem "puma", ">= 5.0"

# Authentication & Authorization
gem "bcrypt", "~> 3.1"
gem "jwt", "~> 2.7"

# CORS
gem "rack-cors"

# Redis client (required by Sidekiq, Rack::Attack cache store, ActionCable)
gem "redis", ">= 4.0.1"

# Background Jobs
gem "sidekiq", "~> 7.2"

# HTTP Client (for calling Go Core)
gem "faraday", "~> 2.8"
gem "faraday-follow_redirects", "~> 0.3"

# Environment Variables
gem "dotenv", groups: [ :development, :test ]

# Data migrations — versioned, one-shot data backfills tracked separately
# from schema changes. Adds bin/rails data:migrate (and the combined
# db:migrate:with_data) so deploys run schema first, then data.
gem "data_migrate"

# Rate Limiting
gem "rack-attack"

# Error Tracking & Monitoring
gem "sentry-ruby", "~> 5.17"
gem "sentry-rails", "~> 5.17"
gem "sentry-sidekiq", "~> 5.17"

# Database-backed adapters
gem "solid_cache"
gem "solid_queue"
gem "solid_cable"

# Boot optimization
gem "bootsnap", require: false

# Deployment
gem "kamal", require: false
gem "thruster", require: false

# Asset processing
gem "image_processing", "~> 1.2"

# Windows timezone support
gem "tzinfo-data", platforms: %i[ windows jruby ]

group :development, :test do
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"
  gem "bundler-audit", require: false
  gem "brakeman", require: false
  gem "rubocop-rails-omakase", require: false
  gem "rspec-rails", "~> 7.0"
  gem "simplecov", require: false
  gem "factory_bot_rails"
  gem "database_cleaner-active_record"
  gem "webmock"
  gem "shoulda-matchers"
end
