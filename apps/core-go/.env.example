# CourierX Core (Go Execution Plane) Configuration

# Server Configuration
PORT=8080
GO_ENV=development

# Database (Shared with Rails Control Plane)
DATABASE_URL="postgresql://username:password@localhost:5432/courierx"

# Email Provider API Keys (Retrieved from DB, but can be overridden for testing)
SENDGRID_API_KEY=""
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Redis (for job queue - future)
REDIS_URL="redis://localhost:6379/0"

# Monitoring & Logging
LOG_LEVEL="info"
LOG_FORMAT="json"

# Performance Tuning
MAX_WORKERS=100
QUEUE_BUFFER_SIZE=1000
RATE_LIMIT_PER_PROVIDER=1000

# Security
WEBHOOK_SECRET=""

# Rails Control Plane API (for fetching configuration)
CONTROL_PLANE_URL="http://localhost:4000"
CONTROL_PLANE_SECRET="shared-secret-between-go-and-rails"

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=false
ENABLE_IP_WARMING=false
